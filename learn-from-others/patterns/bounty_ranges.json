  "severity_definitions": {
    "Critical": {
      "definition": "Direct impact on sensitive data, authentication bypass, or remote code execution affecting production systems",
      "examples": ["RCE on production server", "SQL injection with full database access", "Authentication bypass to admin", "SSRF to cloud credentials"],
      "typical_bounty": "$5,000 - $50,000+"
    },
    "High": {
      "definition": "Significant security impact, access to sensitive data, or ability to affect other users",
      "examples": ["Stored XSS with cookie theft", "IDOR accessing other users data", "Privilege escalation", "SSRF to internal services"],
      "typical_bounty": "$1,000 - $10,000"
    },
    "Medium": {
      "definition": "Limited security impact, requires specific conditions or user interaction",
      "examples": ["Reflected XSS", "CSRF on non-critical action", "Blind SQL injection", "Open redirect"],
      "typical_bounty": "$200 - $2,000"
    },
    "Low": {
      "definition": "Minimal security impact, information disclosure with low sensitivity",
      "examples": ["Self-XSS", "Version disclosure", "Missing security headers", "Verbose error messages"],
      "typical_bounty": "$100 - $500"
    }
  }
